root = true

[*]
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

[*.yml]
indent_style = space
indent_size = 2

# Don't try to reformat test files
[*.{als,pl}]
indent_style = unset
indent_size = unset
insert_final_newline = false
trim_trailing_whitespace = false
